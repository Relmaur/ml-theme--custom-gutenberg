{
    "apiVersion": 2,
    "name": "my-theme/hero",
    "title": "Hero Section",
    "category": "design",
    "render": "file:./render.php",
    "supports": {
        "lock": false,
        "reusable": false,
        "html": false
    },
    "attributes": {
        "lock": {
            "type": "object",
            "default": {
                "move": true,
                "remove": true
            }
        },
        "title": {
            "type": "string",
            "default": "Welcome"
        },
        "subtitle": {
            "type": "string"
        },
        "imageUrl": {
            "type": "string"
        },
        "imageId": {
            "type": "number"
        },
        "backgroundColor": {
            "type": "string",
            "default": "#000000"
        }
    }
}